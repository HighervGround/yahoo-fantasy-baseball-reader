{
  "name": "yahoo-fantasy-baseball-reader",
  "version": "1.0.0",
  "description": "Download your fantasy baseball data from Yahoo's API.",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "league-prefix": "node src/getLeaguePrefix.js",
    "normalize": "node src/normalizeSnapshot.js",
    "advice-context": "node src/buildAdviceContext.js",
    "web-context": "node src/fetchWebContext.js",
    "advice-pipeline": "node src/normalizeSnapshot.js && node src/buildAdviceContext.js && node src/fetchWebContext.js",
    "advise": "node src/runAdvise.js",
    "daily": "node src/runAdvise.js --refresh"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/edwarddistel/yahoo-fantasy-baseball-reader"
  },
  "keywords": [],
  "author": "Edward Distel",
  "license": "ISC",
  "dependencies": {
    "axios": "1.14.0",
    "qs": "6.15.0",
    "fast-xml-parser": "5.2.5"
  }
}
